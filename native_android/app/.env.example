# Copy to app/.env (gitignored) and fill in. Values are read at build time via
# react-native-dotenv and consumed in src/config.ts.

# Splunk RUM access token (O11y → Settings → Access Tokens, RUM authorization).
SPLUNK_RUM_ACCESS_TOKEN=

# AppDynamics mobile (EUM) app key — only needed if rum.provider = 'appdynamics'.
APPDYNAMICS_APP_KEY=
