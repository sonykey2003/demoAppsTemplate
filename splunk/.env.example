# ─────────────────────────────────────────────────────────────────────────────
# Splunk demo scenarios — shared environment config
#
# Copy to splunk/.env and fill in. splunk/.env is gitignored so secrets never
# get committed.
#
# Secrets may be raw values OR 1Password refs (op://...). Any value starting with
# "op://" can be resolved at runtime via `op read`.
#
# Scenarios live under splunk/scripts/. Each scenario sources this file.
# ─────────────────────────────────────────────────────────────────────────────

# ── Splunk Observability Cloud ───────────────────────────────────────────────
export SPLUNK_REALM="us1"                     # e.g. us0, us1, eu0, ap0
export SPLUNK_ACCESS_TOKEN=""                 # O11y access token (Settings > Access Tokens)
export CLUSTER_NAME="port-ops-demo"
export ENVIRONMENT="port-ops-demo"

# ── Scenario: federated / distributed search + O11y Log Observer Connect ─────
# Two Splunk instances, federated together. The REMOTE instance is the LOC-ready
# one (reachable from O11y so APM "Related Logs" works); ON-PREM is the local/
# self-managed peer. ACS stack + URL are Splunk Cloud specifics — for a truly
# self-managed Enterprise on-prem instance, ACS does not apply (it uses its own
# management/HEC API on :8089/:8088 instead).
#
# Splunk Cloud stack name = subdomain of https://<stack>.splunkcloud.com
# ACS API base URL: requests go to <ACS_URL>/<stack>/adminconfig/v2/...
# Use staging for non-production stacks; production stacks use https://admin.splunk.com

# On-prem instance
export SPLUNK_ONPREM_STACK=""
export SPLUNK_ONPREM_ACS_URL="https://staging.admin.splunk.com"
# ACS / JWT bearer token for the on-prem stack. Leave empty — step 2 creates it.
export SPLUNK_ONPREM_ACS_TOKEN=""

# Remote instance (LOC-ready)
export SPLUNK_REMOTE_STACK=""
export SPLUNK_REMOTE_ACS_URL="https://staging.admin.splunk.com"
# ACS / JWT bearer token for the remote stack. Leave empty — step 2 creates it.
export SPLUNK_REMOTE_ACS_TOKEN=""

# Splunk Cloud admin user used to CREATE the ACS tokens (needs sc_admin / ACS caps).
# The password is NOT stored here — step 2 prompts for it interactively.
export SPLUNK_USERNAME=""
# Metadata for the tokens step 2 creates.
export SPLUNK_TOKEN_AUDIENCE="o11y-log-observer-connect"
export SPLUNK_TOKEN_EXPIRES_ON="+90d"   # relative (+<n>[smhd]) or absolute YYYY-MM-DDTHH:MM:SS
# Index the app logs land in (created on both instances; used by LOC srchIndexesAllowed).
export SPLUNK_INDEX="port_ops_demo"
# HEC token name created on the on-prem instance for log collection (step 4).
export SPLUNK_HEC_TOKEN_NAME="port-ops-demo-hec"
# Log Observer Connect service account created on the LOC-ready instance (step 3).
export SPLUNK_LOC_SERVICE_ACCOUNT=""
export SPLUNK_LOC_SERVICE_PASSWORD=""   # set your own; not stored elsewhere
export SPLUNK_LOC_ROLE="o11y_loc_role"  # cloned 'user' role scoped to SPLUNK_INDEX
# Destination subnet(s) the on-prem instance may reach on port 8085 for federated
# search (step 5) — the REMOTE instance's public IP(s) as CIDRs ("203.0.113.10/32").
# Leave empty to auto-resolve from the remote host (SPLUNK_REMOTE_HOST or
# <SPLUNK_REMOTE_STACK>.splunkcloud.com).
export SPLUNK_FED_SUBNETS=""# On-prem FSH egress subnet(s) added to the REMOTE's search-api IP allow list (step 5b).
# Leave empty to auto-resolve from the on-prem host (SPLUNK_ONPREM_HOST or
# <SPLUNK_ONPREM_STACK>.splunkcloud.com).
export SPLUNK_FSH_SUBNETS=""