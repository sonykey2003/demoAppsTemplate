# ─────────────────────────────────────────────────────────────────────────────
# Splunk integration config (shared by splunk-instrumentation.sh and splunk-logs.sh)
#
# Copy to scripts/splunk-integration.env and fill in. That file is gitignored so
# secrets never get committed.
#
# There are TWO separate scripts:
#   A. scripts/splunk-instrumentation.sh — Splunk Observability Cloud instrumentation
#      (traces/metrics/profiling; Secure Application optional). The base path.
#      Run `splunk-instrumentation.sh all`. Needs only the
#      "Splunk Observability Cloud" section below.
#   B. scripts/splunk-logs.sh         — OPTIONAL trace-correlated logs via Splunk
#      Cloud Platform + Log Observer Connect, layered on top of A.
#      Run `splunk-logs.sh all`. Additionally needs the
#      "Splunk Cloud Platform" section below.
#
# Secrets may be raw values OR 1Password refs (op://...). Any value starting with
# "op://" is resolved at runtime via `op read`.
# ─────────────────────────────────────────────────────────────────────────────

# ── A. Splunk Observability Cloud (REQUIRED for splunk-instrumentation.sh) ────
# Traces, metrics, profiling. No Splunk Cloud stack needed.
export SPLUNK_REALM="us1"                     # e.g. us0, us1, eu0, ap0
# O11y access token (Settings > Access Tokens). Raw value or an op:// reference.
export SPLUNK_ACCESS_TOKEN=""
export CLUSTER_NAME="port-ops-demo"
export ENVIRONMENT="port-ops-demo"

# Collector / cluster placement.
export APP_NAMESPACE="port-ops-demo"         # where the Java services run
export OTEL_NAMESPACE="port-ops-demo"        # where the collector + operator install
export HELM_RELEASE="splunk-otel-collector"

export PROFILING_ENABLED="true"
export DISCOVERY_ENABLED="true"
# Splunk Secure Application is OPT-IN. Set to "true" here, or pass --secure-app to
# splunk-instrumentation.sh, to turn it on.
export SECURE_APP_ENABLED="false"

# ── B. Splunk Cloud Platform + Log Observer Connect (OPTIONAL) ────────────────
# Only needed for scripts/splunk-logs.sh (trace-correlated logs via Log Observer
# Connect). Leave blank if you only want the O11y instrumentation.
#
# Stack name is the subdomain of your Splunk Cloud URL: https://<stack>.splunkcloud.com
export SPLUNK_STACK=""
# ACS / JWT bearer token from Splunk Web: Settings > Tokens (needs admin/ACS rights).
# Raw value or an op:// reference.
export SPLUNK_ACS_TOKEN=""

# Index this app's logs land in (created by splunk-logs.sh).
export SPLUNK_INDEX="port_ops_demo"
export SPLUNK_INDEX_SEARCHABLE_DAYS="90"
export SPLUNK_INDEX_MAX_SIZE_MB="0"          # 0 = use stack default / DDAA

# HEC token used by the collector to ship logs into SPLUNK_INDEX.
export SPLUNK_HEC_NAME="port-ops-demo-hec"
export SPLUNK_HEC_TOKEN=""                   # leave empty to auto-create via ACS
# Derived from SPLUNK_STACK by default (Splunk Cloud pattern). Override with a full
# URL for Splunk Enterprise or a custom HEC host (e.g. https://<host>:8088/services/collector).
export SPLUNK_HEC_URL="https://http-inputs-${SPLUNK_STACK}.splunkcloud.com/services/collector"
