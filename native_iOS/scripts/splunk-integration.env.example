# ─────────────────────────────────────────────────────────────────────────────
# Splunk O11y instrumentation config for the SEA Bank demo (backend APM).
# Copy to scripts/splunk-integration.env and fill in. That file is gitignored.
#
# Secrets may be raw values OR 1Password refs (op://...), resolved via `op read`.
# ─────────────────────────────────────────────────────────────────────────────

export SPLUNK_REALM="us1"                    # e.g. us0, us1, eu0, ap0
export SPLUNK_ACCESS_TOKEN=""                # O11y access token (raw or op://...)

export CLUSTER_NAME="sea-bank-demo"
export ENVIRONMENT="shawn-rum"               # deployment.environment tag

# Collector installs in its OWN namespace, separate from the app.
export APP_NAMESPACE="sea-bank-demo"         # where the Node services run
export OTEL_NAMESPACE="splunk-otel"          # where the collector + operator install
export HELM_RELEASE="splunk-otel-collector"

export PROFILING_ENABLED="false"
export DISCOVERY_ENABLED="true"

# This is a self-contained (standalone) config. Fill SPLUNK_REALM + SPLUNK_ACCESS_TOKEN
# with your own values. To avoid storing the raw token, use a 1Password ref instead,
# e.g.  export SPLUNK_ACCESS_TOKEN="op://<vault>/<item>/credential"  (resolved at runtime).
